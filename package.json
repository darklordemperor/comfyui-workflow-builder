{
  "name": "comfyui-workflow-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "node scripts/dev.mjs",
    "dev:server": "node --experimental-strip-types server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "example": "node --experimental-strip-types examples/generate-workflow.ts",
    "test": "node --test --experimental-strip-types src/tests/*.test.ts server/tests/*.test.ts",
    "test:web": "vitest run --config web/vitest.config.ts",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
